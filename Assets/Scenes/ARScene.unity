  m_Script: {fileID: 11500000, guid: 01de49b0b53a30c4ea1e399fca8736d5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ProductInfoManager
  productPanel: {fileID: 1377726406}
  productNameText: {fileID: 1791386100}
  detailsText: {fileID: 902387596}
  showDetailsButton: {fileID: 1258772236}
  detailsPanel: {fileID: 1840346118}
  products:
  - imageName: starville_cleanser
    productName: Starville Cleanser
    details: '\n\n\n\n\n\n\n\n\nWhitening Cleanser for Oily Skin\n\nSkin Type: Oily
      & Acne-Prone\n\nKey Ingredients: Salicylic Acid, Vitamin C, Tea Tree Oil\n\nHow
      To Use: Apply on wet face, massage gently for 30 seconds, then rinse\n\nSize:
      200ml\n\nPrice: 185 EGP'
  - imageName: avene
    productName: Avene Thermal Water
    details: '\n\n\n\n\n\n\n\n\nThermal Spring Water Spray\n\nSkin Type: All Skin
      Types\n\nKey Ingredients: Avene Thermal Spring Water\n\nHow To Use: Spray on
      face from 20cm distance, leave for 2-3 minutes, pat dry\n\nSize: 150ml\n\nPrice:
      250 EGP'
  - imageName: bioderma
    productName: Bioderma Micellar
    details: '\n\n\n\n\n\n\n\n\nSensibio H2O Micellar Water\n\nSkin Type: Sensitive
      Skin\n\nKey Ingredients: Micellar Technology, Cucumber Extract\n\nHow To Use:
      Soak cotton pad, gently wipe face and eyes to remove makeup\n\nSize: 250ml\n\nPrice:
      350 EGP'
  - imageName: bioderma_gel
    productName: Bioderma Gel Cleanser
    details: '\n\n\n\n\n\n\n\n\nSebium Gel Moussant Purifying Cleanser\n\nSkin Type:
      Oily & Combination\n\nKey Ingredients: Zinc, Copper, Vitamin B6\n\nHow To Use:
      Apply on wet skin, lather gently, rinse with water\n\nSize: 200ml\n\nPrice:
      320 EGP'
  - imageName: cerave
    productName: CeraVe Lotion
    details: '\n\n\n\n\n\n\n\n\nMoisturizing Cream for Dry Skin\n\nSkin Type: Normal
      to Dry\n\nKey Ingredients: Ceramides, Hyaluronic Acid, MVE Technology\n\nHow
      To Use: Apply generously on face and body after cleansing\n\nSize: 340g\n\nPrice:
      450 EGP'
  - imageName: cetaphel
    productName: cetaphel Cleanser
    details: '\n\n\n\n\n\n\n\n\nGentle Skin Cleanser\n\nSkin Type: Normal to Dry,
      Sensitive\n\nKey Ingredients: Niacinamide, Glycerin, Panthenol\n\nHow To Use:
      Apply on wet or dry skin, massage gently, rinse off\n\nSize: 473ml\n\nPrice:
      320 EGP'
  - imageName: cleanclear
    productName: Clean & Clear Face Wash
    details: '\n\n\n\n\n\n\n\n\nFoaming Face Wash for Oily Skin\n\nSkin Type: Oily
      & Acne-Prone\n\nKey Ingredients: Salicylic Acid, Glycerin, Aloe Vera\n\nHow
      To Use: Wet face, apply small amount, massage and rinse\n\nSize: 150ml\n\nPrice:
      120 EGP'
  - imageName: eucerin
    productName: Eucerin Repair Cream
    details: '\n\n\n\n\n\n\n\n\nUltraSensitive Deep Moisture Cream\n\nSkin Type:
      Dry & Sensitive\n\nKey Ingredients: Ceramides, Natural Moisturizing Factors\n\nHow
      To Use: Apply morning and night on cleansed face\n\nSize: 50ml\n\nPrice: 380
      EGP'
  - imageName: neutorgina
    productName: Neutrogena Face Wash
    details: '\n\n\n\n\n\n\n\n\nOil-Free Acne Wash\n\nSkin Type: Oily & Acne-Prone\n\nKey
      Ingredients: Salicylic Acid 2%, Aloe Vera, Chamomile\n\nHow To Use: Wet face,
      apply and gently massage, rinse thoroughly\n\nSize: 177ml\n\nPrice: 200 EGP'
  - imageName: garnier
    productName: Garnier SkinActive
    details: '\n\n\n\n\n\n\n\n\nMicellar Cleansing Water\n\nSkin Type: All Skin Types\n\nKey
      Ingredients: Micelles, Rose Water, Glycerin\n\nHow To Use: Soak cotton pad,
      wipe gently across face, no rinsing needed\n\nSize: 400ml\n\nPrice: 150 EGP'
  - imageName: vaseline
    productName: Vaseline Moisturizer
    details: '\n\n\n\n\n\n\n\n\nIntensive Care Body Lotion\n\nSkin Type: Dry Skin\n\nKey
      Ingredients: Petroleum Jelly, Glycerin, Micro-Droplets of Vaseline\n\nHow To
      Use: Apply all over body after shower on damp skin\n\nSize: 400ml\n\nPrice:
      130 EGP'
